# TikTok Hook Finder - API Keys
# Replace the placeholders with your actual keys

# ScrapeCreators TikTok API Key (https://scrapecreators.com/tiktok-api)
SCRAPE_CREATORS_API_KEY=YOUR_SCRAPE_CREATORS_KEY

# Anthropic API Key (Claude Vision OCR)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# OpenAI API Key (used for embeddings and GPT Image 2 generation)
OPENAI_API_KEY=YOUR_OPENAI_KEY

# API access keys for public API (comma-separated)
API_KEYS=your_tool_key_1,your_tool_key_2
